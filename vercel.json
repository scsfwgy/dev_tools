{
  "outputDirectory": "frontend",
  "regions": ["hkg1"],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/robots.txt", "destination": "/api/index" },
    { "source": "/sitemap.xml", "destination": "/api/index" },
    { "source": "/favicon.ico", "destination": "/favicon.svg" },
    { "source": "/", "destination": "/api/index" },
    { "source": "/(zh|en)", "destination": "/api/index" },
    { "source": "/(zh|en)/", "destination": "/api/index" },
    { "source": "/(zh|en)/tool/(.*)", "destination": "/api/index" },
    { "source": "/(zh|en)/(converter|flutter|android|ios)/(.*)", "destination": "/api/index" }
  ],
  "headers": [
    {
      "source": "/css/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/js/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/locales/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400, stale-while-revalidate=604800" }]
    }
  ],
  "functions": {
    "api/index.py": {
      "memory": 512,
      "maxDuration": 30
    }
  }
}
